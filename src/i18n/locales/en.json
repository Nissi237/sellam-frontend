  "about": {
    "title": "About Sellam",
    "lead": "Sellam is a digital marketplace built for Cameroon: it brings individual buyers, market sellers and corporate buyers together in one trusted app.",
    "missionTitle": "Our mission",
    "missionBody": "To make online commerce safe, trustworthy and accessible for everyone. We connect informal merchants with buyers across the city through escrow-protected Mobile Money payment, tracked delivery and verified sellers — so anyone can buy and sell with confidence.",
    "storyTitle": "Our story",
    "storyBody": "Sellam grew from a simple observation in the markets of Douala: merchants and buyers had no unified, reliable channel to transact online safely. The platform was built to close that gap and bridge retail and business-to-business (B2B) trade.",
    "valuesTitle": "Our values",
    "values": [
      "Trust — verified accounts, reviews and escrow-protected payment.",
      "Accessibility — mobile-first, right down to low-end phones.",
      "Community — supporting local sellers and neighbourhood trade."
    ],
    "whatTitle": "What Sellam offers",
    "what": [
      "Catalogue and search for fresh produce and groceries.",
      "Mobile Money payment (MTN & Orange) held in escrow, released on delivery.",
      "Real-time delivery tracking.",
      "B2B quotes with live chat for bulk purchasing.",
      "Reviews, loyalty and an administration console."
    ],
    "ctaTitle": "Join the marketplace",
    "ctaText": "Sell your goods to the whole city, or find what you need from verified sellers.",
    "ctaSell": "Become a seller",
    "ctaBrowse": "Explore the market"
  },
