  "faq": {
    "title": "Frequently asked questions",
    "subtitle": "Everything you need to know about buying and selling on Sellam.",
    "items": [
      { "q": "How do I place an order?", "a": "Browse the catalogue, add items to your cart, then pay with Mobile Money. The amount is held in escrow until delivery is confirmed." },
      { "q": "What is escrow payment?", "a": "Your payment is held securely by Sellam and only released to the seller once the order is delivered — protecting both buyer and seller." },
      { "q": "Which payment methods are accepted?", "a": "MTN Mobile Money and Orange Money. You link your account once, then pay in one step at checkout." },
      { "q": "How do I become a seller?", "a": "Create a seller account, link your Mobile Money account, and submit your ID and a stall photo for verification. You can then list your products." },
      { "q": "How does delivery work?", "a": "A partner delivery agent picks up your order and you follow their location in real time until it arrives." },
      { "q": "Can I buy in bulk (B2B)?", "a": "Yes. Corporate buyers can send a request for quotation (RFQ), negotiate live with sellers and place volume orders." },
      { "q": "What if an item is wrong or doesn't arrive?", "a": "Because funds stay in escrow until delivery, contact us and the dispute is reviewed before any payout to the seller." }
    ]
  },
